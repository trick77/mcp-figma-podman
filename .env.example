# Runtime + build-time config for figma-console-mcp. Copy to .env and edit.
# .env is gitignored. install-systemd.sh chmods it to 600.

# --- REQUIRED at runtime: Figma Personal Access Token ---
#
# Create at https://www.figma.com/developers/api#access-tokens.
# Grant ONLY read scopes:
#   - File content:    Read-only
#   - Variables:       Read-only
#   - Dev resources:   Read-only (optional)
#   - Library content: Read-only (optional)
# Do NOT grant any "Write" scopes. Bridge-style write tools fail anyway
# because no Desktop Bridge listener runs in this image, but the read-only
# PAT scope is what stops a REST write attempt at api.figma.com — Figma
# returns 403 server-side. Both layers protect you; don't rely on either
# alone.
#
# Read by the systemd unit (EnvironmentFile=) and forwarded into the spawned
# node child by mcp-proxy via --pass-environment. Never bake into the image.
#
# ROTATION: Figma PATs expire after 90 days max. To rotate, replace the value
# below and restart the service:
#   systemctl --user restart figma-console-mcp.service   # Quadlet
#   podman-compose restart                               # compose
# See README "Rotating the PAT" for the full flow.
FIGMA_ACCESS_TOKEN=figd_replace-me

# --- Build-time overrides (consumed by scripts/build.sh) ---

# npm registry override (e.g. corporate mirror).
#NPM_REGISTRY=https://registry.npmjs.org/

# Pin a specific upstream release tag. Use the leading 'v' (that's the
# upstream git tag).
#
# v1.20.0 is the last release with a tools/list schema that strict LLM
# providers (Anthropic, OpenAI) accept. v1.21+ ship a malformed JSON schema
# for figma_check_design_parity that gets the whole tools/list rejected.
# Tracked upstream as southleft/figma-console-mcp#64. Bump only after fix.
VERSION=v1.20.0
